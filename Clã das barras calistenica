<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clã das Barras - CT de Treinamento</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&family=Bebas+Neue&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background: #0f0f0f;
            color: #ffffff;
            overflow-x: hidden;
        }
        
        .font-clan {
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 0.05em;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
        }
        
        .card-glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        .exercise-card {
            transition: all 0.3s ease;
        }
        
        .exercise-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(220, 38, 38, 0.2);
        }
        
        .level-badge {
            background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
        }
        
        .timer-circle {
            stroke-dasharray: 283;
            stroke-dashoffset: 283;
            transition: stroke-dashoffset 1s linear;
        }
        
        .muscle-group {
            transition: all 0.3s ease;
        }
        
        .muscle-group:hover {
            transform: scale(1.05);
            filter: brightness(1.2);
        }
        
        .progress-bar {
            transition: width 0.5s ease;
        }
        
        .hidden-section {
            display: none;
        }
        
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .pulse {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .difficulty-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 4px;
        }
        
        .difficulty-easy { background: #22c55e; }
        .difficulty-medium { background: #eab308; }
        .difficulty-hard { background: #dc2626; }
        
        .logo-glow {
            filter: drop-shadow(0 0 20px rgba(220, 38, 38, 0.5));
        }
        
        .nav-blur {
            background: rgba(15, 15, 15, 0.95);
            backdrop-filter: blur(10px);
        }
        
        .btn-clan {
            background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
            box-shadow: 0 4px 20px rgba(220, 38, 38, 0.4);
        }
        
        .btn-clan:hover {
            box-shadow: 0 6px 30px rgba(220, 38, 38, 0.6);
            transform: translateY(-2px);
        }
        
        .border-clan {
            border-color: #dc2626;
        }
        
        .text-clan {
            color: #dc2626;
        }
        
        .bg-clan {
            background-color: #dc2626;
        }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-b from-gray-900 to-black">

    <!-- Navigation -->
    <nav class="fixed top-0 w-full nav-blur z-50 border-b border-red-900/20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <div class="flex items-center space-x-4 cursor-pointer" onclick="showSection('home')">
                    <img src="/mnt/kimi/upload/1000023020.jpg" alt="Clã das Barras" class="w-12 h-12 rounded-full object-cover logo-glow">
                    <div class="flex flex-col">
                        <span class="text-2xl font-clan font-bold tracking-wider text-white">CLÃ DAS BARRAS</span>
                        <span class="text-xs text-red-500 font-clan tracking-widest">CT DE TREINAMENTO</span>
                    </div>
                </div>
                <div class="hidden md:flex space-x-8">
                    <button onclick="showSection('home')" class="hover:text-red-500 transition font-clan text-lg tracking-wide">INÍCIO</button>
                    <button onclick="showSection('workouts')" class="hover:text-red-500 transition font-clan text-lg tracking-wide">TREINOS</button>
                    <button onclick="showSection('skills')" class="hover:text-red-500 transition font-clan text-lg tracking-wide">HABILIDADES</button>
                    <button onclick="showSection('progress')" class="hover:text-red-500 transition font-clan text-lg tracking-wide">PROGRESSO</button>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400 font-clan tracking-wider">NÍVEL ATUAL</div>
                        <div class="text-sm font-bold text-red-500 font-clan tracking-wider" id="currentLevelDisplay">INICIANTE</div>
                    </div>
                    <button onclick="toggleProfile()" class="w-12 h-12 rounded-full bg-gradient-to-br from-red-600 to-red-900 flex items-center justify-center shadow-lg shadow-red-500/30">
                        <i class="fas fa-user text-white"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Home Section -->
    <section id="home" class="pt-28 pb-12 px-4 min-h-screen">
        <div class="max-w-7xl mx-auto">
            <!-- Hero -->
            <div class="text-center mb-16 fade-in">
                <div class="mb-8 flex justify-center">
                    <img src="/mnt/kimi/upload/1000023020.jpg" alt="Clã das Barras Logo" class="w-32 h-32 rounded-full object-cover logo-glow mb-4">
                </div>
                <h1 class="text-6xl md:text-8xl font-clan font-black mb-6 leading-none tracking-tight">
                    CLÃ DAS<br>
                    <span class="text-red-600">BARRAS</span>
                </h1>
                <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-4 font-clan tracking-wide">
                    CT DE TREINAMENTO • SINCE 2024
                </p>
                <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
                    Do primeiro push-up ao muscle-up. Evolua com a metodologia do <strong>Personal Mark</strong> e torne-se parte do clã.
                </p>
                <div class="flex justify-center gap-4">
                    <button onclick="showSection('workouts')" class="px-10 py-5 btn-clan rounded-full font-clan font-bold text-xl hover:scale-105 transition transform tracking-wider">
                        COMEÇAR TREINO <i class="fas fa-arrow-right ml-2"></i>
                    </button>
                    <button onclick="showSection('skills')" class="px-10 py-5 border-2 border-red-600 rounded-full font-clan font-bold text-xl hover:bg-red-600/10 transition tracking-wider">
                        VER HABILIDADES
                    </button>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-16">
                <div class="card-glass rounded-2xl p-6 text-center border border-red-500/20">
                    <div class="text-4xl font-clan font-bold text-red-500 mb-2">4</div>
                    <div class="text-sm text-gray-400 font-clan tracking-wider">NÍVEIS DE DIFICULDADE</div>
                </div>
                <div class="card-glass rounded-2xl p-6 text-center border border-red-500/20">
                    <div class="text-4xl font-clan font-bold text-red-500 mb-2">50+</div>
                    <div class="text-sm text-gray-400 font-clan tracking-wider">EXERCÍCIOS</div>
                </div>
                <div class="card-glass rounded-2xl p-6 text-center border border-red-500/20">
                    <div class="text-4xl font-clan font-bold text-red-500 mb-2">12</div>
                    <div class="text-sm text-gray-400 font-clan tracking-wider">SEMANAS DE PROGRAMA</div>
                </div>
                <div class="card-glass rounded-2xl p-6 text-center border border-red-500/20">
                    <div class="text-4xl font-clan font-bold text-red-500 mb-2">0</div>
                    <div class="text-sm text-gray-400 font-clan tracking-wider">EQUIPAMENTO</div>
                </div>
            </div>

            <!-- Level Selection -->
            <h2 class="text-4xl font-clan font-bold mb-8 text-center tracking-wide">ESCOLHA SEU NÍVEL</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div onclick="selectLevel('beginner')" class="cursor-pointer exercise-card card-glass rounded-2xl p-6 border-l-4 border-green-500 hover:bg-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-xs font-clan font-bold tracking-wider">INICIANTE</span>
                        <i class="fas fa-seedling text-green-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-clan font-bold mb-2 tracking-wide">FUNDAÇÕES</h3>
                    <p class="text-sm text-gray-400 mb-4">Aprenda push-ups, agachamentos e barras. Construa base sólida.</p>
                    <ul class="text-sm space-y-2 text-gray-300">
                        <li><i class="fas fa-check text-green-400 mr-2"></i>Push-ups inclinados</li>
                        <li><i class="fas fa-check text-green-400 mr-2"></i>Remadas australianas</li>
                        <li><i class="fas fa-check text-green-400 mr-2"></i>Agachamentos</li>
                    </ul>
                </div>

                <div onclick="selectLevel('intermediate')" class="cursor-pointer exercise-card card-glass rounded-2xl p-6 border-l-4 border-yellow-500 hover:bg-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded-full text-xs font-clan font-bold tracking-wider">INTERMEDIÁRIO</span>
                        <i class="fas fa-fire text-yellow-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-clan font-bold mb-2 tracking-wide">FORÇA & CONDICIONAMENTO</h3>
                    <p class="text-sm text-gray-400 mb-4">Dominando pull-ups, dips e variações avançadas.</p>
                    <ul class="text-sm space-y-2 text-gray-300">
                        <li><i class="fas fa-check text-yellow-400 mr-2"></i>Pull-ups strictos</li>
                        <li><i class="fas fa-check text-yellow-400 mr-2"></i>Dips na barra</li>
                        <li><i class="fas fa-check text-yellow-400 mr-2"></i>Pike push-ups</li>
                    </ul>
                </div>

                <div onclick="selectLevel('advanced')" class="cursor-pointer exercise-card card-glass rounded-2xl p-6 border-l-4 border-orange-500 hover:bg-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-3 py-1 bg-orange-500/20 text-orange-400 rounded-full text-xs font-clan font-bold tracking-wider">AVANÇADO</span>
                        <i class="fas fa-bolt text-orange-400 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-clan font-bold mb-2 tracking-wide">SKILLS & POTÊNCIA</h3>
                    <p class="text-sm text-gray-400 mb-4">Muscle-ups, handstands e levers. Dominação total.</p>
                    <ul class="text-sm space-y-2 text-gray-300">
                        <li><i class="fas fa-check text-orange-400 mr-2"></i>Muscle-ups</li>
                        <li><i class="fas fa-check text-orange-400 mr-2"></i>Handstand holds</li>
                        <li><i class="fas fa-check text-orange-400 mr-2"></i>Front lever</li>
                    </ul>
                </div>

                <div onclick="selectLevel('elite')" class="cursor-pointer exercise-card card-glass rounded-2xl p-6 border-l-4 border-red-600 hover:bg-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <span class="px-3 py-1 bg-red-600/20 text-red-500 rounded-full text-xs font-clan font-bold tracking-wider">ELITE</span>
                        <i class="fas fa-crown text-red-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-clan font-bold mb-2 tracking-wide">MOVIMENTOS EXTREMOS</h3>
                    <p class="text-sm text-gray-400 mb-4">One-arm skills, planches e movimentos de alto nível.</p>
                    <ul class="text-sm space-y-2 text-gray-300">
                        <li><i class="fas fa-check text-red-500 mr-2"></i>One-arm pull-up</li>
                        <li><i class="fas fa-check text-red-500 mr-2"></i>Planche</li>
                        <li><i class="fas fa-check text-red-500 mr-2"></i>Human flag</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Workouts Section -->
    <section id="workouts" class="pt-28 pb-12 px-4 hidden-section min-h-screen">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-center mb-8">
                <div>
                    <h2 class="text-5xl font-clan font-bold mb-2 tracking-wide">TREINOS DO DIA</h2>
                    <p class="text-gray-400 font-clan tracking-wider">SELECIONE SEU NÍVEL E COMECE O TREINO</p>
                </div>
                <div class="flex gap-2 mt-4 md:mt-0">
                    <button onclick="filterWorkouts('all')" class="px-4 py-2 rounded-full bg-white/10 hover:bg-red-600/20 transition text-sm font-clan tracking-wider">TODOS</button>
                    <button onclick="filterWorkouts('push')" class="px-4 py-2 rounded-full bg-red-500/20 text-red-400 hover:bg-red-500/30 transition text-sm font-clan tracking-wider">PUSH</button>
                    <button onclick="filterWorkouts('pull')" class="px-4 py-2 rounded-full bg-blue-500/20 text-blue-400 hover:bg-blue-500/30 transition text-sm font-clan tracking-wider">PULL</button>
                    <button onclick="filterWorkouts('legs')" class="px-4 py-2 rounded-full bg-green-500/20 text-green-400 hover:bg-green-500/30 transition text-sm font-clan tracking-wider">LEGS</button>
                    <button onclick="filterWorkouts('core')" class="px-4 py-2 rounded-full bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30 transition text-sm font-clan tracking-wider">CORE</button>
                </div>
            </div>

            <div id="workoutContainer" class="space-y-6">
                <!-- Workouts will be populated by JavaScript -->
            </div>
        </div>
    </section>

    <!-- Active Workout Modal -->
    <div id="activeWorkout" class="fixed inset-0 bg-black/95 z-50 hidden flex items-center justify-center p-4">
        <div class="max-w-2xl w-full">
            <div class="card-glass rounded-3xl p-8 relative border border-red-500/30">
                <button onclick="closeWorkout()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
                
                <div class="text-center mb-8">
                    <div class="text-sm text-red-500 font-clan tracking-widest mb-2" id="workoutCategory">CATEGORIA</div>
                    <h2 class="text-4xl font-clan font-bold mb-4 tracking-wide" id="workoutTitle">Nome do Treino</h2>
                    <div class="flex justify-center gap-4 text-sm font-clan tracking-wider">
                        <span class="px-4 py-2 bg-white/10 rounded-full"><i class="fas fa-clock mr-2"></i><span id="workoutDuration">30 min</span></span>
                        <span class="px-4 py-2 bg-white/10 rounded-full"><i class="fas fa-fire mr-2"></i><span id="workoutIntensity">Alta</span></span>
                    </div>
                </div>

                <div id="exerciseList" class="space-y-4 mb-8 max-h-96 overflow-y-auto">
                    <!-- Exercises populated by JS -->
                </div>

                <div class="flex gap-4">
                    <button onclick="startTimer()" class="flex-1 py-5 btn-clan rounded-xl font-clan font-bold text-xl hover:scale-105 transition tracking-wider">
                        <i class="fas fa-play mr-2"></i>INICIAR TREINO
                    </button>
                    <button onclick="showExerciseDemo()" class="px-6 py-5 border-2 border-red-600 rounded-xl hover:bg-red-600/10 transition">
                        <i class="fas fa-video text-red-500"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Timer Overlay -->
    <div id="timerOverlay" class="fixed inset-0 bg-black/95 z-[60] hidden flex items-center justify-center">
        <div class="text-center">
            <div class="mb-8">
                <img src="/mnt/kimi/upload/1000023020.jpg" alt="Clã das Barras" class="w-24 h-24 rounded-full mx-auto logo-glow mb-4">
            </div>
            <div class="relative w-64 h-64 mx-auto mb-8">
                <svg class="w-full h-full transform -rotate-90">
                    <circle cx="128" cy="128" r="120" stroke="rgba(255,255,255,0.1)" stroke-width="8" fill="none"/>
                    <circle id="timerCircle" class="timer-circle" cx="128" cy="128" r="120" stroke="#dc2626" stroke-width="8" fill="none"/>
                </svg>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="text-6xl font-clan font-bold" id="timerDisplay">00:00</div>
                </div>
            </div>
            <h3 class="text-3xl font-clan font-bold mb-4 tracking-wide" id="timerExercise">DESCANSO</h3>
            <div class="flex justify-center gap-4">
                <button onclick="toggleTimer()" class="w-16 h-16 rounded-full btn-clan flex items-center justify-center text-2xl hover:scale-110 transition">
                    <i class="fas fa-pause" id="timerIcon"></i>
                </button>
                <button onclick="skipTimer()" class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center text-2xl hover:bg-red-600/20 transition">
                    <i class="fas fa-forward text-red-500"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Skills Section -->
    <section id="skills" class="pt-28 pb-12 px-4 hidden-section min-h-screen">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-5xl font-clan font-bold mb-4 tracking-wide">ÁRVORE DE HABILIDADES</h2>
                <p class="text-center text-gray-400 mb-8 max-w-2xl mx-auto font-clan tracking-wider">
                    ACOMPANHE SUA PROGRESSÃO ATRAVÉS DAS HABILIDADES MAIS DESAFIADORAS DA CALISTENIA
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Push Skills -->
                <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                    <h3 class="text-2xl font-clan font-bold mb-6 flex items-center text-red-500 tracking-wider">
                        <i class="fas fa-arrow-up mr-3"></i>PUSH SKILLS
                    </h3>
                    <div class="space-y-4" id="pushSkills">
                        <!-- Populated by JS -->
                    </div>
                </div>

                <!-- Pull Skills -->
                <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                    <h3 class="text-2xl font-clan font-bold mb-6 flex items-center text-red-500 tracking-wider">
                        <i class="fas fa-arrow-down mr-3"></i>PULL SKILLS
                    </h3>
                    <div class="space-y-4" id="pullSkills">
                        <!-- Populated by JS -->
                    </div>
                </div>

                <!-- Core Skills -->
                <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                    <h3 class="text-2xl font-clan font-bold mb-6 flex items-center text-red-500 tracking-wider">
                        <i class="fas fa-circle mr-3"></i>CORE SKILLS
                    </h3>
                    <div class="space-y-4" id="coreSkills">
                        <!-- Populated by JS -->
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Progress Section -->
    <section id="progress" class="pt-28 pb-12 px-4 hidden-section min-h-screen">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-5xl font-clan font-bold mb-8 tracking-wide">SEU PROGRESSO</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                    <h3 class="text-xl font-clan font-bold mb-4 tracking-wider">NÍVEL ATUAL</h3>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-3xl font-clan font-bold text-red-500" id="progressLevel">INICIANTE</span>
                        <span class="text-sm text-gray-400 font-clan tracking-wider" id="progressPercent">0% PARA PRÓXIMO NÍVEL</span>
                    </div>
                    <div class="w-full bg-white/10 rounded-full h-4 mb-4">
                        <div id="levelProgressBar" class="progress-bar bg-gradient-to-r from-red-600 to-red-900 h-4 rounded-full" style="width: 0%"></div>
                    </div>
                    <p class="text-sm text-gray-400 font-clan tracking-wider">COMPLETE MAIS 5 TREINOS PARA DESBLOQUEAR O PRÓXIMO NÍVEL</p>
                </div>

                <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                    <h3 class="text-xl font-clan font-bold mb-4 tracking-wider">ESTATÍSTICAS</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="text-center p-4 bg-white/5 rounded-xl border border-red-500/10">
                            <div class="text-3xl font-clan font-bold text-red-500" id="totalWorkouts">0</div>
                            <div class="text-xs text-gray-400 font-clan tracking-wider">TREINOS COMPLETOS</div>
                        </div>
                        <div class="text-center p-4 bg-white/5 rounded-xl border border-red-500/10">
                            <div class="text-3xl font-clan font-bold text-red-500" id="totalTime">0</div>
                            <div class="text-xs text-gray-400 font-clan tracking-wider">MINUTOS TREINADOS</div>
                        </div>
                        <div class="text-center p-4 bg-white/5 rounded-xl border border-red-500/10">
                            <div class="text-3xl font-clan font-bold text-red-500" id="currentStreak">0</div>
                            <div class="text-xs text-gray-400 font-clan tracking-wider">DIAS SEGUIDOS</div>
                        </div>
                        <div class="text-center p-4 bg-white/5 rounded-xl border border-red-500/10">
                            <div class="text-3xl font-clan font-bold text-red-500" id="skillsUnlocked">0</div>
                            <div class="text-xs text-gray-400 font-clan tracking-wider">SKILLS DESBLOQUEADAS</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-glass rounded-2xl p-6 border border-red-500/20">
                <h3 class="text-xl font-clan font-bold mb-6 tracking-wider">HISTÓRICO DE TREINOS</h3>
                <div id="workoutHistory" class="space-y-3">
                    <div class="text-center text-gray-500 py-8 font-clan tracking-wider">NENHUM TREINO REGISTRADO AINDA. COMECE HOJE!</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black/50 border-t border-red-900/20 py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <img src="/mnt/kimi/upload/1000023020.jpg" alt="Clã das Barras" class="w-16 h-16 rounded-full mx-auto mb-4 logo-glow">
            <h3 class="text-2xl font-clan font-bold mb-2">CLÃ DAS BARRAS</h3>
