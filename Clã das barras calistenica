        let currentExerciseIndex = 0;

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            loadProgress();
            renderWorkouts();
            renderSkills();
            updateStats();
        });

        function showSection(sectionId) {
            document.querySelectorAll('section').forEach(section => {
                section.classList.add('hidden-section');
            });
            
            const selected = document.getElementById(sectionId);
            selected.classList.remove('hidden-section');
            selected.classList.add('fade-in');
            
            window.scrollTo(0, 0);
        }

        function selectLevel(level) {
            currentLevel = level;
            const levelNames = {
                beginner: 'INICIANTE',
                intermediate: 'INTERMEDIÁRIO',
                advanced: 'AVANÇADO',
                elite: 'ELITE'
            };
            document.getElementById('currentLevelDisplay').textContent = levelNames[level];
            showSection('workouts');
            renderWorkouts();
            localStorage.setItem('calisthenicsLevel', level);
        }

        function renderWorkouts() {
            const container = document.getElementById('workoutContainer');
            container.innerHTML = '';
            
            const workouts = workoutData[currentLevel] || [];
            
            workouts.forEach(workout => {
                const card = document.createElement('div');
                card.className = 'exercise-card card-glass rounded-2xl p-6 cursor-pointer border border-red-500/10 hover:border-red-500/30';
                card.onclick = () => openWorkout(workout);
                
                const difficultyDots = Array(3).fill(0).map((_, i) => 
                    `<span class="difficulty-dot ${i < (workout.difficulty === 'easy' ? 1 : workout.difficulty === 'medium' ? 2 : 3) ? 
                        (workout.difficulty === 'easy' ? 'difficulty-easy' : 
                         workout.difficulty === 'medium' ? 'difficulty-medium' : 'difficulty-hard') : 'bg-gray-600'}"></span>`
                ).join('');
                
                card.innerHTML = `
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center space-x-3">
                            <span class="px-3 py-1 rounded-full text-xs font-clan font-bold tracking-wider ${getCategoryColor(workout.category)}">
                                ${workout.category.toUpperCase()}
                            </span>
                            <div class="flex">${difficultyDots}</div>
                        </div>
                        <i class="fas fa-chevron-right text-red-500"></i>
                    </div>
                    <h3 class="text-xl font-clan font-bold mb-2 tracking-wide">${workout.title}</h3>
                    <div class="flex items-center space-x-4 text-sm text-gray-400 font-clan tracking-wider">
                        <span><i class="fas fa-clock mr-2 text-red-500"></i>${workout.duration}</span>
                        <span><i class="fas fa-dumbbell mr-2 text-red-500"></i>${workout.exercises.length} EXERCÍCIOS</span>
                    </div>
                `;
                
                container.appendChild(card);
            });
        }

        function getCategoryColor(category) {
            const colors = {
                push: 'bg-red-500/20 text-red-400',
                pull: 'bg-blue-500/20 text-blue-400',
                legs: 'bg-green-500/20 text-green-400',
                core: 'bg-yellow-500/20 text-yellow-400',
                full: 'bg-purple-500/20 text-purple-400'
            };
            return colors[category] || 'bg-gray-500/20 text-gray-400';
        }

        function openWorkout(workout) {
            currentWorkout = workout;
            document.getElementById('workoutTitle').textContent = workout.title;
            document.getElementById('workoutCategory').textContent = workout.category.toUpperCase();
            document.getElementById('workoutDuration').textContent = workout.duration;
            document.getElementById('workoutIntensity').textContent = 
                workout.difficulty === 'easy' ? 'BAIXA' : 
                workout.difficulty === 'medium' ? 'MÉDIA' : 'ALTA';
            
            const list = document.getElementById('exerciseList');
            list.innerHTML = '';
            
            workout.exercises.forEach((ex, idx) => {
                const item = document.createElement('div');
                item.className = 'flex items-center justify-between p-4 bg-white/5 rounded-xl border border-red-500/10';
                item.innerHTML = `
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-red-600 to-red-900 flex items-center justify-center font-clan font-bold text-lg">
                            ${idx + 1}
                        </div>
                        <div>
                            <div class="font-clan font-bold tracking-wide">${ex.name}</div>
                            <div class="text-sm text-gray-400 font-clan tracking-wider">${ex.sets} SETS × ${ex.reps}</div>
                        </div>
                    </div>
                    <div class="text-sm text-gray-400 font-clan tracking-wider">
                        <i class="fas fa-stopwatch mr-1 text-red-500"></i>${ex.rest}S
                    </div>
                `;
                list.appendChild(item);
            });
            
            document.getElementById('activeWorkout').classList.remove('hidden');
        }

        function closeWorkout() {
            document.getElementById('activeWorkout').classList.add('hidden');
            stopTimer();
        }

        function startTimer() {
            document.getElementById('timerOverlay').classList.remove('hidden');
            currentExerciseIndex = 0;
            startRestTimer(currentWorkout.exercises[0].rest);
        }

        function startRestTimer(seconds) {
            timeLeft = seconds;
            updateTimerDisplay();
            
            if (timerInterval) clearInterval(timerInterval);
            
            timerInterval = setInterval(() => {
                if (timerRunning) {
                    timeLeft--;
                    updateTimerDisplay();
                    
                    if (timeLeft <= 0) {
                        nextExercise();
                    }
                }
            }, 1000);
            
            timerRunning = true;
        }

        function updateTimerDisplay() {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            document.getElementById('timerDisplay').textContent = 
                `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            
            const maxTime = currentWorkout.exercises[currentExerciseIndex]?.rest || 60;
            const offset = 283 - (timeLeft / maxTime) * 283;
            document.getElementById('timerCircle').style.strokeDashoffset = offset;
            
            const nextEx = currentWorkout.exercises[currentExerciseIndex + 1];
            document.getElementById('timerExercise').textContent = 
                nextEx ? `PRÓXIMO: ${nextEx.name.toUpperCase()}` : 'TREINO FINALIZADO!';
        }

        function toggleTimer() {
            timerRunning = !timerRunning;
            document.getElementById('timerIcon').className = 
                timerRunning ? 'fas fa-pause' : 'fas fa-play';
        }

        function skipTimer() {
            nextExercise();
        }

        function nextExercise() {
            currentExerciseIndex++;
            if (currentExerciseIndex < currentWorkout.exercises.length) {
                startRestTimer(currentWorkout.exercises[currentExerciseIndex].rest);
            } else {
                finishWorkout();
            }
        }

        function finishWorkout() {
            stopTimer();
            document.getElementById('timerOverlay').classList.add('hidden');
            document.getElementById('activeWorkout').classList.add('hidden');
            
            saveWorkoutCompletion(currentWorkout);
            
            alert('PARABÉNS! TREINO COMPLETADO! 💪🔥');
            updateStats();
        }

        function stopTimer() {
            if (timerInterval) clearInterval(timerInterval);
            timerRunning = false;
        }

        function renderSkills() {
            renderSkillCategory('pushSkills', skillsData.push, 'red');
            renderSkillCategory('pullSkills', skillsData.pull, 'red');
            renderSkillCategory('coreSkills', skillsData.core, 'red');
        }

        function renderSkillCategory(containerId, skills, color) {
            const container = document.getElementById(containerId);
            container.innerHTML = '';
            
            skills.forEach((skill, idx) => {
                const div = document.createElement('div');
                div.className = `flex items-center justify-between p-3 rounded-lg ${skill.unlocked ? 'bg-red-500/10 border border-red-500/30' : 'bg-white/5 border border-white/10'}`;
                div.innerHTML = `
                    <div class="flex items-center space-x-3">
                        <div class="w-8 h-8 rounded-full ${skill.unlocked ? 'bg-red-600' : 'bg-gray-600'} flex items-center justify-center text-xs font-clan font-bold">
                            ${skill.level}
                        </div>
                        <span class="${skill.unlocked ? 'text-white font-clan tracking-wider' : 'text-gray-400 font-clan tracking-wider'}">${skill.name}</span>
                    </div>
                    ${skill.unlocked ? '<i class="fas fa-check text-red-500"></i>' : '<i class="fas fa-lock text-gray-600"></i>'}
                `;
                container.appendChild(div);
            });
        }

        function saveWorkoutCompletion(workout) {
            let history = JSON.parse(localStorage.getItem('workoutHistory') || '[]');
            history.push({
                date: new Date().toISOString(),
                workout: workout.title,
                level: currentLevel,
                duration: workout.duration
            });
            localStorage.setItem('workoutHistory', JSON.stringify(history));
            
            let stats = JSON.parse(localStorage.getItem('userStats') || '{"totalWorkouts":0,"totalTime":0,"streak":0,"lastWorkout":null}');
            stats.totalWorkouts++;
            stats.totalTime += parseInt(workout.duration);
            
            const today = new Date().toDateString();
            const lastWorkout = stats.lastWorkout ? new Date(stats.lastWorkout).toDateString() : null;
            const yesterday = new Date();
            yesterday.setDate(yesterday.getDate() - 1);
            
            if (lastWorkout === yesterday.toDateString()) {
                stats.streak++;
            } else if (lastWorkout !== today) {
                stats.streak = 1;
            }
            
            stats.lastWorkout = new Date().toISOString();
            localStorage.setItem('userStats', JSON.stringify(stats));
        }

        function updateStats() {
            const stats = JSON.parse(localStorage.getItem('userStats') || '{"totalWorkouts":0,"totalTime":0,"streak":0}');
            document.getElementById('totalWorkouts').textContent = stats.totalWorkouts;
            document.getElementById('totalTime').textContent = stats.totalTime;
            document.getElementById('currentStreak').textContent = stats.streak;
            
            const workoutsNeeded = 10;
            const progress = Math.min((stats.totalWorkouts % workoutsNeeded) / workoutsNeeded * 100, 100);
            document.getElementById('levelProgressBar').style.width = progress + '%';
            document.getElementById('progressPercent').textContent = Math.floor(progress) + '% PARA PRÓXIMO NÍVEL';
            
            const history = JSON.parse(localStorage.getItem('workoutHistory') || '[]');
            const historyContainer = document.getElementById('workoutHistory');
            
            if (history.length > 0) {
                historyContainer.innerHTML = history.slice(-5).reverse().map(h => `
                    <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-red-500/10">
                        <div>
                            <div class="font-clan font-bold tracking-wide">${h.workout}</div>
                            <div class="text-sm text-gray-400 font-clan tracking-wider">${new Date(h.date).toLocaleDateString('pt-BR')}</div>
                        </div>
                        <span class="px-3 py-1 rounded-full text-xs ${getCategoryColor(h.level)} font-clan tracking-wider">
                            ${h.level.toUpperCase()}
                        </span>
                    </div>
                `).join('');
            }
        }

        function loadProgress() {
            const savedLevel = localStorage.getItem('calisthenicsLevel');
            if (savedLevel) {
                currentLevel = savedLevel;
                const levelNames = {
                    beginner: 'INICIANTE',
                    intermediate: 'INTERMEDIÁRIO',
                    advanced: 'AVANÇADO',
                    elite: 'ELITE'
                };
                document.getElementById('currentLevelDisplay').textContent = levelNames[savedLevel];
            }
        }

        function filterWorkouts(category) {
            const cards = document.querySelectorAll('#workoutContainer > div');
            cards.forEach(card => {
                const cat = card.querySelector('.px-3').textContent.toLowerCase();
                if (category === 'all' || cat === category) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

